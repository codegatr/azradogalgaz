# =========================================================
# Azra Doğalgaz — .htaccess  (v1.12.25 — SEO uyumluluğu)
# DirectAdmin / Apache 2.4 + LiteSpeed uyumlu
# =========================================================

Options -Indexes -MultiViews
DirectoryIndex index.php index.html
ServerSignature Off

# UTF-8 default charset
AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---------- TEK-HOP REDIRECT (HTTPS + www birleşik) ----------
    # Önce: HTTP/HTTPS + www/non-www kombinasyonları → tek-hop
    # https://azradogalgaz.com (canonical) — tüm diğerleri 301 burada birleşir.
    RewriteCond %{HTTP_HOST} ^www\.azradogalgaz\.com$ [NC,OR]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://azradogalgaz.com/$1 [L,R=301,NE]

    # ---------- IndexNow key file passthrough ----------
    # Bing/Yandex IndexNow protokolü key doğrulaması için
    RewriteRule ^([a-f0-9]{32})\.txt$ - [L]

    # ---------- Sitemap & Feed ----------
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^sitemap-(images|news|sayfalar|hizmetler|urunler)\.xml$ sitemap.php?tur=$1 [L,QSA]
    RewriteRule ^rss\.xml$ rss.php [L]
    RewriteRule ^opensearch\.xml$ opensearch.php [L]

    # ---------- SEO dostu URL'ler ----------
    RewriteRule ^hizmet/([a-z0-9\-]+)/?$ hizmet.php?slug=$1 [L,QSA]
    RewriteRule ^urun/([a-z0-9\-]+)/?$ urun.php?slug=$1 [L,QSA]
    RewriteRule ^kampanya/([a-z0-9\-]+)/?$ kampanya.php?slug=$1 [L,QSA]
    RewriteRule ^blog/([a-z0-9\-]+)/?$ blog.php?slug=$1 [L,QSA]
    RewriteRule ^kategori/([a-z0-9\-]+)/?$ kategori.php?slug=$1 [L,QSA]

    # ---------- v1.12.27 — 81 il SEO landing pattern ----------
    # /iller                              → 81 il hub sayfası
    # /il/izmir                           → İzmir tüm hizmetler
    # /il/izmir/dogalgaz-tesisati         → İzmir × Doğalgaz Tesisatı
    RewriteRule ^iller/?$ iller.php [L]
    RewriteRule ^il/([a-z0-9\-]+)/([a-z0-9\-]+)/?$ il.php?il=$1&hizmet=$2 [L,QSA]
    RewriteRule ^il/([a-z0-9\-]+)/?$ il.php?il=$1 [L,QSA]

    # Statik sayfalar
    RewriteRule ^hakkimizda/?$ hakkimizda.php [L]
    RewriteRule ^iletisim/?$ iletisim.php [L]
    RewriteRule ^hizmetler/?$ hizmetler.php [L]
    RewriteRule ^urunler/?$ urunler.php [L]
    RewriteRule ^kampanyalar/?$ kampanyalar.php [L]
    RewriteRule ^blog/?$ blog.php [L]
    RewriteRule ^kvkk/?$ kvkk.php [L]
    RewriteRule ^gizlilik/?$ gizlilik.php [L]
    RewriteRule ^cerez/?$ cerez.php [L]
    RewriteRule ^mesafeli/?$ mesafeli.php [L]
    RewriteRule ^iade/?$ iade.php [L]

    RewriteRule ^kesif/?$ kesif.php [L]
    RewriteRule ^projeler/?$ projeler.php [L]
    RewriteRule ^sss/?$ sss.php [L]
    RewriteRule ^kombi-hesaplama/?$ kombi-hesaplama.php [L]
    RewriteRule ^klima-hesaplama/?$ klima-hesaplama.php [L]
    RewriteRule ^bilgi-bankasi/?$ bilgi-bankasi.php [L]

    # Trailing slash kaldır (canonical'la tutarlı tek URL)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]
</IfModule>

# ---------- Hassas dosyaları engelle ----------
<FilesMatch "^(\.htaccess|\.htpasswd|config\.php|manifest\.json|composer\.json|composer\.lock|\.env|\.git.*|.*\.sql|.*\.md|.*\.log)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^(\.git|inc|api/private|migrations|vendor)(/|$) - [F,L]
</IfModule>

# ---------- Güvenlik başlıkları (geliştirilmiş) ----------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
    Header set X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1"
    Header unset X-Powered-By
    Header always unset Server
    # Canonical link header — bots HTML parse etmeden de canonical'i bilebilsin
    Header set Link '<https://azradogalgaz.com%{REQUEST_URI}e>; rel="canonical"' "expr=%{REQUEST_URI} =~ /^\/(hakkimizda|iletisim|hizmetler|urunler|kampanyalar|sss|kesif|projeler|bilgi-bankasi)?$/"
</IfModule>

# ---------- Gzip / Deflate ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE application/rss+xml application/xhtml+xml image/svg+xml
    AddOutputFilterByType DEFLATE application/atom+xml application/ld+json
</IfModule>

# ---------- Tarayıcı önbelleği ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType application/xml               "access plus 1 hour"
    ExpiresByType application/rss+xml           "access plus 1 hour"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
</IfModule>

# ---------- PHP ayarları ----------
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_execution_time 120
    php_value memory_limit 256M
</IfModule>

# ---------- Hata sayfaları ----------
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
ErrorDocument 500 /404.php
