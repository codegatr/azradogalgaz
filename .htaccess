# =========================================================
# Azra Doğalgaz — .htaccess  (v1.1.1 — kurulum.php hatası düzeltildi)
# DirectAdmin / Apache 2.4 + LiteSpeed uyumlu
# =========================================================

Options -Indexes -MultiViews
DirectoryIndex index.php index.html

# ---------- HTTPS & www yönlendirmesi ----------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTPS zorunlu
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # www -> non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # ---------- Sitemap ----------
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # ---------- SEO dostu URL'ler ----------
    RewriteRule ^hizmet/([a-z0-9\-]+)/?$ hizmet.php?slug=$1 [L,QSA]
    RewriteRule ^urun/([a-z0-9\-]+)/?$ urun.php?slug=$1 [L,QSA]
    RewriteRule ^kampanya/([a-z0-9\-]+)/?$ kampanya.php?slug=$1 [L,QSA]
    RewriteRule ^blog/([a-z0-9\-]+)/?$ blog.php?slug=$1 [L,QSA]
    RewriteRule ^kategori/([a-z0-9\-]+)/?$ kategori.php?slug=$1 [L,QSA]

    # Statik sayfalar
    RewriteRule ^hakkimizda/?$ hakkimizda.php [L]
    RewriteRule ^iletisim/?$ iletisim.php [L]
    RewriteRule ^hizmetler/?$ hizmetler.php [L]
    RewriteRule ^urunler/?$ urunler.php [L]
    RewriteRule ^kampanyalar/?$ kampanyalar.php [L]
    RewriteRule ^blog/?$ blog.php [L]
    RewriteRule ^kvkk/?$ kvkk.php [L]
    RewriteRule ^gizlilik/?$ gizlilik.php [L]

    # Trailing slash kaldır
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]
</IfModule>

# ---------- Hassas dosyaları engelle ----------
# NOT: kurulum.php burada KASTEN YASAKLI DEĞİL.
# Kurulum tamamlanınca dosyayı MANUEL SİLİN. Sistem zaten kilit dosyası ile
# 2. çalıştırmayı engeller; ama dosyanın kendisi sunucuda kalmamalı.
<FilesMatch "^(\.htaccess|\.htpasswd|config\.php|manifest\.json|composer\.json|composer\.lock|\.env|\.git.*|.*\.sql)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^(\.git|inc|api/private)(/|$) - [F,L]
</IfModule>

# ---------- Güvenlik başlıkları ----------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header unset X-Powered-By
    Header always unset Server
</IfModule>

# ---------- Gzip / Deflate ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE application/rss+xml application/xhtml+xml image/svg+xml
</IfModule>

# ---------- Tarayıcı önbelleği ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
</IfModule>

# ---------- PHP ayarları ----------
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_execution_time 120
    php_value memory_limit 256M
</IfModule>

# ---------- Hata sayfaları ----------
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
ErrorDocument 500 /404.php
